---
<section class="hero">
	<div class="hero-bg">
		<div class="grid-overlay"></div>
		<div class="radar"></div>
		
		<!-- 3D Satellite Container -->
		<div id="three-hero-container" class="three-hero-bg"></div>

		<!-- Swarm of Drones -->
		<div class="drone-swarm">
			<div class="drone d1"></div>
			<div class="drone d2"></div>
			<div class="drone d3"></div>
			<div class="drone d4"></div>
			<div class="drone d5"></div>
			<div class="drone d6"></div>
			<div class="drone d7"></div>
			<div class="drone d8"></div>
			<div class="drone d9"></div>
			<div class="drone d10"></div>
		</div>
	</div>

	<div class="container">
		<div class="hero-content">
			<span class="eyebrow">Defence and Dual-Use Private Equity</span>
			<h1>Securing the <br/> <span class="text-highlight">Future of Europe</span></h1>
			<p>Strategic investments in defence and dual-use scale-ups across the EU and NATO ecosystem.</p>
			<div class="hero-actions">
				<a href="/investment-strategies" class="btn">View Strategies</a>
				<a href="#mission" class="scroll-down">
					<span>Learn More</span>
					<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M10 4V16M10 16L4 10M10 16L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	import * as THREE from 'three';

	function initHero3D() {
		const container = document.getElementById('three-hero-container');
		if (!container) return;

		const scene = new THREE.Scene();
		const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
		camera.position.set(5, 2, 10);
		camera.lookAt(0, 0, 0);

		const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
		renderer.setSize(container.clientWidth, container.clientHeight);
		renderer.setPixelRatio(window.devicePixelRatio);
		container.appendChild(renderer.domElement);

		const satelliteGroup = new THREE.Group();
		scene.add(satelliteGroup);

		const lineMaterial = new THREE.LineBasicMaterial({ 
			color: 0xeeeae1, 
			transparent: true, 
			opacity: 0.25 
		});

		const pointMaterial = new THREE.PointsMaterial({
			color: 0xeeeae1,
			size: 0.05,
			transparent: true,
			opacity: 0.4
		});

		// 1. Core Body
		const bodyGeo = new THREE.BoxGeometry(1, 2, 1);
		const bodyEdges = new THREE.EdgesGeometry(bodyGeo);
		const bodyLine = new THREE.LineSegments(bodyEdges, lineMaterial);
		satelliteGroup.add(bodyLine);

		// 2. Solar Panels
		const createPanel = (side) => {
			const panelGroup = new THREE.Group();
			const panelGeo = new THREE.BoxGeometry(4, 1.5, 0.05);
			const panelLine = new THREE.LineSegments(new THREE.EdgesGeometry(panelGeo), lineMaterial);
			panelGroup.add(panelLine);

			for (let i = -1.5; i <= 1.5; i += 0.5) {
				const gv = new THREE.BoxGeometry(0.01, 1.5, 0.06);
				const l = new THREE.LineSegments(new THREE.EdgesGeometry(gv), lineMaterial);
				l.position.x = i;
				panelGroup.add(l);
			}

			panelGroup.position.x = side * 3;
			satelliteGroup.add(panelGroup);
		};
		createPanel(1);
		createPanel(-1);

		// 3. Sensors
		const dishGeo = new THREE.ConeGeometry(0.5, 0.7, 12, 1, true);
		const dishLine = new THREE.LineSegments(new THREE.EdgesGeometry(dishGeo), lineMaterial);
		dishLine.position.y = -1.5;
		dishLine.rotation.x = Math.PI;
		satelliteGroup.add(dishLine);

		const points = new THREE.Points(bodyEdges, pointMaterial);
		satelliteGroup.add(points);

		// 4. Wireframe Earth (Very subtle)
		const earthGeo = new THREE.SphereGeometry(30, 32, 32);
		const earthLine = new THREE.LineSegments(new THREE.EdgesGeometry(earthGeo), new THREE.LineBasicMaterial({ color: 0xeeeae1, transparent: true, opacity: 0.03 }));
		earthLine.position.set(-10, -35, -5);
		scene.add(earthLine);

		// Interaction
		let mouseX = 0;
		let mouseY = 0;
		window.addEventListener('mousemove', (e) => {
			mouseX = (e.clientX / window.innerWidth) - 0.5;
			mouseY = (e.clientY / window.innerHeight) - 0.5;
		});

		function animate() {
			requestAnimationFrame(animate);
			
			satelliteGroup.rotation.y += 0.002;
			satelliteGroup.rotation.x += 0.0005;

			// Subtle mouse follow
			satelliteGroup.position.x += (mouseX * 2 - satelliteGroup.position.x) * 0.05;
			satelliteGroup.position.y += (-mouseY * 2 - satelliteGroup.position.y) * 0.05;
			
			earthLine.rotation.y += 0.0002;
			
			renderer.render(scene, camera);
		}

		window.addEventListener('resize', () => {
			const width = container.clientWidth;
			const height = container.clientHeight;
			renderer.setSize(width, height);
			camera.aspect = width / height;
			camera.updateProjectionMatrix();
		});

		animate();
	}

	initHero3D();
</script>

<style>
	.hero {
		height: 100vh;
		display: flex;
		align-items: center;
		position: relative;
		overflow: hidden;
		background: radial-gradient(circle at 50% 50%, #1e2b42 0%, #182132 100%);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.three-hero-bg {
		position: absolute;
		inset: 0;
		z-index: 1;
		opacity: 0.8;
	}

	.grid-overlay {
		position: absolute;
		inset: 0;
		background-image: 
			linear-gradient(rgba(238, 234, 225, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(238, 234, 225, 0.05) 1px, transparent 1px);
		background-size: 50px 50px;
		mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
		z-index: 0;
	}

	.radar {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 800px;
		height: 800px;
		border: 1px solid rgba(238, 234, 225, 0.08);
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.radar::before {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: 50%;
		background: conic-gradient(from 0deg, transparent 0deg, rgba(238, 234, 225, 0.1) 90deg, transparent 90deg);
		animation: rotate 12s linear infinite;
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Drone Swarm Styling */
	.drone-swarm {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 2;
	}

	.drone {
		position: absolute;
		width: 36px;
		height: 36px;
		color: rgba(238, 234, 225, 0.1);
		pointer-events: none;
	}

	.drone::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 4.5px;
		height: 4.5px;
		background: currentColor;
		border-radius: 50%;
	}

	.drone::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 7.5px;
		height: 7.5px;
		border: 1px solid currentColor;
		border-radius: 50%;
		box-shadow: 
			-9px -9px 0 0 rgba(238, 234, 225, 0.05),
			9px -9px 0 0 rgba(238, 234, 225, 0.05),
			-9px 9px 0 0 rgba(238, 234, 225, 0.05),
			9px 9px 0 0 rgba(238, 234, 225, 0.05);
	}

	.d1 { top: 15%; left: -60px; animation: drift-1 30s linear infinite; }
	.d2 { top: 40%; right: -60px; animation: drift-2 35s linear infinite; }
	.d3 { top: 65%; left: -60px; animation: drift-1 40s linear infinite; animation-delay: 10s; }
	.d4 { top: 25%; right: -60px; animation: drift-2 28s linear infinite; animation-delay: 5s; }
	.d5 { top: 80%; left: -60px; animation: drift-1 45s linear infinite; animation-delay: 2s; }
	.d6 { top: 55%; left: -60px; animation: drift-1 32s linear infinite; animation-delay: 7s; }
	.d7 { top: 10%; right: -60px; animation: drift-2 42s linear infinite; animation-delay: 3s; }
	.d8 { top: 70%; right: -60px; animation: drift-2 38s linear infinite; animation-delay: 12s; }
	.d9 { top: 33%; left: -60px; animation: drift-1 36s linear infinite; animation-delay: 1s; }
	.d10 { top: 85%; right: -60px; animation: drift-2 48s linear infinite; }

	@keyframes drift-1 {
		0% { left: -60px; transform: translateY(0); }
		50% { transform: translateY(15px); }
		100% { left: 110%; }
	}

	@keyframes drift-2 {
		0% { right: -60px; transform: translateY(0); }
		50% { transform: translateY(-15px); }
		100% { right: 110%; }
	}

	.hero-content {
		position: relative;
		z-index: 10;
		max-width: 800px;
	}

	.eyebrow {
		display: block;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		margin-bottom: 1.5rem;
		color: rgba(238, 234, 225, 0.6);
	}

	h1 {
		font-size: clamp(3rem, 8vw, 5.5rem);
		line-height: 0.95;
		margin-bottom: 2rem;
	}

	.text-highlight {
		color: transparent;
		-webkit-text-stroke: 1px var(--color-secondary);
	}

	p {
		font-size: 1.25rem;
		max-width: 550px;
		margin-bottom: 3rem;
		opacity: 0.8;
		line-height: 1.5;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 3rem;
	}

	.btn {
		display: inline-block;
		padding: 1.25rem 3rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
	}

	.btn-outline {
		background-color: transparent;
		color: var(--color-secondary);
		border: 1px solid var(--color-secondary);
	}

	.scroll-down {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.6;
	}

	.scroll-down svg {
		animation: bounce 2s infinite;
	}

	@keyframes bounce {
		0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
		40% { transform: translateY(-5px); }
		60% { transform: translateY(-3px); }
	}

	@media (max-width: 768px) {
		.hero-actions {
			flex-direction: column;
			align-items: flex-start;
			gap: 2rem;
		}
	}
</style>
