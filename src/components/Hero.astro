---
---
<section class="hero">
	<div class="hero-bg">
		<div class="grid-overlay"></div>
		<div class="radar"></div>
		
		<!-- Floating Satellite SVG -->
		<div class="satellite-container">
			<svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="satellite-svg">
				<rect x="70" y="90" width="60" height="20" rx="2" fill="currentColor" fill-opacity="0.2"/>
				<rect x="85" y="80" width="30" height="40" rx="4" stroke="currentColor" stroke-width="2"/>
				<rect x="40" y="85" width="40" height="30" rx="1" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
				<rect x="120" y="85" width="40" height="30" rx="1" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
				<circle cx="100" cy="100" r="3" fill="currentColor"/>
				<path d="M100 80V60M100 60L95 65M100 60L105 65" stroke="currentColor" stroke-width="1.5"/>
			</svg>
		</div>

		<!-- Swarm of Drones -->
		<div class="drone-swarm">
			<div class="drone d1"></div>
			<div class="drone d2"></div>
			<div class="drone d3"></div>
			<div class="drone d4"></div>
			<div class="drone d5"></div>
		</div>
	</div>

	<div class="container">
		<div class="hero-content">
			<span class="eyebrow">Defense Technology Venture Capital</span>
			<h1>Securing the <br/> <span class="text-highlight">Future of Europe</span></h1>
			<p>Strategic investments in Drones, Cybersecurity, and Space Systems to safeguard our democracies.</p>
			<div class="hero-actions">
				<a href="/investment-strategies" class="btn">View Strategies</a>
				<a href="#mission" class="scroll-down">
					<span>Learn More</span>
					<svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M10 4V16M10 16L4 10M10 16L16 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		height: 100vh;
		display: flex;
		align-items: center;
		position: relative;
		overflow: hidden;
		background: radial-gradient(circle at 50% 50%, #1e2b42 0%, #182132 100%);
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.grid-overlay {
		position: absolute;
		inset: 0;
		background-image: 
			linear-gradient(rgba(238, 234, 225, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(238, 234, 225, 0.05) 1px, transparent 1px);
		background-size: 50px 50px;
		mask-image: radial-gradient(circle at 50% 50%, black, transparent 80%);
	}

	.radar {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 800px;
		height: 800px;
		border: 1px solid rgba(238, 234, 225, 0.1);
		border-radius: 50%;
		pointer-events: none;
	}

	.radar::before {
		content: '';
		position: absolute;
		inset: -1px;
		border-radius: 50%;
		background: conic-gradient(from 0deg, transparent 0deg, rgba(238, 234, 225, 0.15) 90deg, transparent 90deg);
		animation: rotate 12s linear infinite;
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Satellite Styling */
	.satellite-container {
		position: absolute;
		top: 15%;
		right: 10%;
		color: var(--color-secondary);
		opacity: 0.3;
		animation: float 20s ease-in-out infinite;
		transform: scale(1.15); /* Reduced from 1.5 */
	}

	.satellite-svg {
		width: 225px; /* Reduced from 300px */
		height: 225px;
		filter: drop-shadow(0 0 10px rgba(238, 234, 225, 0.2));
	}

	@keyframes float {
		0%, 100% { transform: translateY(0) rotate(0deg) scale(1.15); }
		50% { transform: translateY(-30px) rotate(5deg) scale(1.15); }
	}

	/* Drone Swarm Styling */
	.drone-swarm {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.drone {
		position: absolute;
		width: 36px; /* Reduced from 48px */
		height: 36px;
		color: rgba(238, 234, 225, 0.1);
		pointer-events: none;
		transition: color 0.5s ease;
	}

	/* Central Body */
	.drone::before {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 4.5px; /* Reduced from 6px */
		height: 4.5px;
		background: currentColor;
		border-radius: 50%;
	}

	/* 4 Circular Rotors */
	.drone::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 7.5px; /* Reduced from 10px */
		height: 7.5px;
		border: 1px solid currentColor;
		border-radius: 50%;
		box-shadow: 
			-9px -9px 0 0 rgba(238, 234, 225, 0.05),
			9px -9px 0 0 rgba(238, 234, 225, 0.05),
			-9px 9px 0 0 rgba(238, 234, 225, 0.05),
			9px 9px 0 0 rgba(238, 234, 225, 0.05);
	}

	.d1 { top: 15%; left: -60px; animation: drift-1 30s linear infinite; }
	.d2 { top: 40%; right: -60px; animation: drift-2 35s linear infinite; }
	.d3 { top: 65%; left: -60px; animation: drift-1 40s linear infinite; animation-delay: 10s; }
	.d4 { top: 25%; right: -60px; animation: drift-2 28s linear infinite; animation-delay: 5s; }
	.d5 { top: 80%; left: -60px; animation: drift-1 45s linear infinite; animation-delay: 2s; }
	.d6 { top: 55%; left: -60px; animation: drift-1 32s linear infinite; animation-delay: 7s; }
	.d7 { top: 10%; right: -60px; animation: drift-2 42s linear infinite; animation-delay: 3s; }
	.d8 { top: 70%; right: -60px; animation: drift-2 38s linear infinite; animation-delay: 12s; }
	.d9 { top: 33%; left: -60px; animation: drift-1 36s linear infinite; animation-delay: 1s; }
	.d10 { top: 85%; right: -60px; animation: drift-2 48s linear infinite; }

	@keyframes drift-1 {
		0% { left: -60px; transform: translateY(0); }
		50% { transform: translateY(15px); }
		100% { left: 110%; transform: translateY(0); }
	}

	@keyframes drift-2 {
		0% { right: -60px; transform: translateY(0); }
		50% { transform: translateY(-15px); }
		100% { right: 110%; transform: translateY(0); }
	}

	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 800px;
	}

	.eyebrow {
		display: block;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		margin-bottom: 1.5rem;
		color: rgba(238, 234, 225, 0.6);
	}

	h1 {
		font-size: clamp(3rem, 8vw, 5.5rem);
		line-height: 0.95;
		margin-bottom: 2rem;
	}

	.text-highlight {
		color: transparent;
		-webkit-text-stroke: 1px var(--color-secondary);
	}

	p {
		font-size: 1.25rem;
		max-width: 500px;
		margin-bottom: 3rem;
		opacity: 0.8;
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 3rem;
	}

	.btn {
		display: inline-block;
		padding: 1.25rem 3rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
	}

	.scroll-down {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.6;
	}

	.scroll-down svg {
		animation: bounce 2s infinite;
	}

	@keyframes bounce {
		0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
		40% { transform: translateY(-5px); }
		60% { transform: translateY(-3px); }
	}

	@media (max-width: 768px) {
		.hero-actions {
			flex-direction: column;
			align-items: flex-start;
			gap: 2rem;
		}
		.satellite-container {
			top: 5%;
			right: 5%;
			transform: scale(0.6);
		}
	}
</style>
