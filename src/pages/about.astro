---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
	<section class="page-header">
		<div class="container">
			<h1>About Artemis</h1>
			<p>Operator-led investment team for European defense and technological sovereignty.</p>
		</div>
	</section>

	<section class="about-content">
		<div class="container">
			<div class="grid grid-cols-2">
				<div class="about-text">
					<h2>Active Investors</h2>
					<p>Artemis is a Luxembourg-based private equity fund investing in the defence and dual-use technology sector across the EU and NATO ecosystem.</p>
					<p>As active investors, the partners bring deep expertise in structuring, governance, operational transformation, and industrial matchmaking to support the scaling and commercialization of portfolio companies.</p>
				</div>
				<div class="about-stats">
					<div class="feature-list">
						<div class="feature-item">
							<h4>Proprietary Deal Access</h4>
							<p>Deep relationships across the European defence and satellite ecosystem.</p>
						</div>
						<div class="feature-item">
							<h4>Operator-Led Team</h4>
							<p>Partners bring executive leadership experience in telecom, satellite and technology sectors.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="expertise">
		<div class="container">
			<div class="section-header">
				<span class="eyebrow">Why Artemis</span>
				<h2>Deep Industry <span class="outline">Expertise</span></h2>
			</div>
			<div class="grid grid-cols-3">
				<div class="exp-card">
					<h4>Technology</h4>
					<p>Hands-on expertise in satellite communications, electronic warfare, AI and defense technologies.</p>
				</div>
				<div class="exp-card">
					<h4>Governance</h4>
					<p>Experience in private equity management, institutional transformations, and strategic exits.</p>
				</div>
				<div class="exp-card">
					<h4>EU Programs</h4>
					<p>Expertise in EDF, EDIP, SAFE, IRIS², and NATO initiatives.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-header {
		padding-top: 12rem;
		padding-bottom: 6rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
	}

	.about-content { padding: 10rem 0; }
	
	.about-text h2 { margin-bottom: 2rem; }
	.about-text p { margin-bottom: 1.5rem; opacity: 0.8; font-size: 1.1rem; }

	.feature-item { margin-bottom: 3rem; padding-left: 2rem; border-left: 2px solid var(--color-secondary); }
	.feature-item h4 { margin-bottom: 0.5rem; }
	.feature-item p { font-size: 0.9rem; opacity: 0.6; }

	.expertise { padding: 10rem 0; background: #121926; }
	.section-header { margin-bottom: 5rem; }
	.outline { color: transparent; -webkit-text-stroke: 1px var(--color-secondary); }

	.exp-card { padding: 3rem; border: 1px solid rgba(238, 234, 225, 0.05); }
	.exp-card h4 { margin-bottom: 1.5rem; color: var(--color-secondary); }
	.exp-card p { font-size: 0.9rem; opacity: 0.7; }
</style>
