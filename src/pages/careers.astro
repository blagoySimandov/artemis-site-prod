---
import Layout from '../layouts/Layout.astro';

const jobs = [
	{ title: "Investment Associate", location: "Berlin / Munich", type: "Full-time" },
	{ title: "Technical Analyst - Defense Systems", location: "Remote (EU)", type: "Full-time" },
	{ title: "Head of Operations", location: "London / Paris", type: "Full-time" }
];
---

<Layout title="Careers">
	<section class="page-header">
		<div class="container">
			<h1>Join Artemis</h1>
			<p>We are building the team that will secure the next century of European innovation.</p>
		</div>
	</section>

	<section class="careers">
		<div class="container">
			<div class="grid grid-cols-2">
				<div>
					<h2>Culture</h2>
					<p>At Artemis Capital Partners, we value technical excellence, strategic thinking, and a commitment to the security of our democracies. We provide a high-stakes, rewarding environment for those passionate about defense technology.</p>
				</div>
				<div class="jobs-list">
					<h2>Open Positions</h2>
					{jobs.map(job => (
						<div class="job-card">
							<h3>{job.title}</h3>
							<div class="job-meta">
								<span>{job.location}</span>
								<span>{job.type}</span>
							</div>
							<a href="#" class="apply-link">Apply Now &rarr;</a>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-header {
		padding-top: 10rem;
		padding-bottom: 6rem;
	}

	h2 {
		font-size: 2rem;
		margin-bottom: 2rem;
	}

	.jobs-list {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.job-card {
		padding: 2rem;
		border: 1px solid rgba(238, 234, 225, 0.1);
		transition: border-color 0.3s ease;
	}

	.job-card:hover {
		border-color: var(--color-secondary);
	}

	.job-card h3 {
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.job-meta {
		display: flex;
		gap: 1.5rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.6;
		margin-bottom: 1.5rem;
	}

	.apply-link {
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--color-secondary);
	}
</style>
