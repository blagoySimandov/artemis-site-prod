---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Growth">
	<section class="page-header">
		<div class="container">
			<h1>Growth</h1>
			<p>Scaling the champions of European defense tech.</p>
		</div>
	</section>

	<section class="content">
		<div class="container">
			<h2>Expansion Capital</h2>
			<p>We provide late-stage venture and growth capital to companies with proven technology and clear market traction across the EU.</p>
		</div>
	</section>
</Layout>

<style>
	.page-header { padding-top: 12rem; padding-bottom: 6rem; }
	.content { padding: 6rem 0; }
</style>
