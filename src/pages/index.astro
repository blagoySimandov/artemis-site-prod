---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FeatureShowcase from '../components/FeatureShowcase.astro';
import WhyArtemis from '../components/WhyArtemis.astro';
---

<Layout title="European Defense & Security VC">
	<Hero />
	
	<section id="mission" class="mission">
		<div class="container">
			<div class="grid grid-cols-2">
				<div>
					<span class="mission-eyebrow">A GP-Led Pledge Investment Platform</span>
					<h2>European Defence Private Equity</h2>
				</div>
				<div>
					<p class="lead">Artemis Capital Partners invests in established, scaling and transitioning defence companies with disciplined capital, active ownership, and long-term value creation. We target mid-market companies across the EU and NATO ecosystem positioned to benefit from the structural rearmament of Europe.</p>
					<div class="platform-links">
<a href="/investment-strategies" class="platform-link">Investment Strategy</a>
						<a href="/approach" class="platform-link">Approach</a>
					</div>
				</div>
			</div>
		</div>
	</section>
	
	<FeatureShowcase />
	
	<WhyArtemis />

	<section class="cta">
		<div class="container text-center">
			<p>Connect with our team to learn more about our platform and investment opportunities.</p>
			<div class="cta-btns">
				<a href="/approach" class="btn">Our Approach</a>
				<a href="/team" class="btn btn-outline">Our Team</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.mission h2 {
		max-width: 400px;
	}

	.mission-eyebrow {
		display: block;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.75rem;
		opacity: 0.5;
		margin-bottom: 1rem;
	}

	.lead {
		font-size: 1.25rem;
		opacity: 0.9;
		margin-bottom: 2.5rem;
	}

	.platform-links {
		display: flex;
		gap: 2rem;
		flex-wrap: wrap;
	}

	.platform-link {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		font-weight: 600;
		color: var(--color-primary);
		opacity: 0.5;
		text-decoration: none;
		border-bottom: 1px solid rgba(24, 33, 50, 0.3);
		padding-bottom: 2px;
		transition: opacity 0.3s ease;
	}

	.platform-link:hover {
		opacity: 1;
	}

	.mission {
		background-color: var(--color-secondary);
		color: var(--color-primary);
	}

	.text-center {
		text-align: center;
	}

	.partners h2 {
		margin-bottom: 4rem;
	}

	.outline {
		color: transparent;
		-webkit-text-stroke: 1px var(--color-secondary);
	}

	.partners {
		padding: 4rem 0 8rem;
		background-color: var(--color-primary);
	}

	.partners-grid {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 4rem;
		opacity: 0.6;
	}

	.partner-name {
		font-size: 2rem;
		font-weight: 700;
		letter-spacing: 0.2em;
	}

	.cta h2 {
		margin-bottom: 1.5rem;
	}

	.cta p {
		font-size: 1.1rem;
		margin-bottom: 3rem;
		opacity: 0.8;
	}

	.cta-btns {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.btn {
		display: inline-block;
		padding: 1rem 2.5rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.8rem;
	}

	.btn-outline {
		background-color: transparent;
		color: var(--color-secondary);
		border: 1px solid var(--color-secondary);
	}

	.btn:hover {
		opacity: 1;
		transform: translateY(-2px);
	}
</style>
