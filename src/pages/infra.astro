---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Infra">
	<section class="page-header">
		<div class="container">
			<h1>Infrastructure</h1>
			<p>Securing the backbone of European resilience.</p>
		</div>
	</section>

	<section class="content">
		<div class="container">
			<h2>Critical Systems</h2>
			<p>Our infrastructure strategy focuses on the foundational technologies that keep nations running—from secure energy grids to hardened communication networks.</p>
		</div>
	</section>
</Layout>

<style>
	.page-header { padding-top: 12rem; padding-bottom: 6rem; }
	.content { padding: 6rem 0; }
</style>
