---
import Layout from '../layouts/Layout.astro';
---

<Layout title="News & Insights">
	<section class="page-header">
		<div class="container">
			<h1>News & Insights</h1>
			<p>The latest updates from Artemis and the defense industry.</p>
		</div>
	</section>

	<section class="content">
		<div class="container">
			<div class="grid grid-cols-3">
				<div class="news-card">
					<span class="date">April 15, 2026</span>
					<h3>Artemis leads €50M Series B for Drone Guard</h3>
					<p>Strengthening anti-drone capabilities across Eastern Europe.</p>
				</div>
				<!-- More news items -->
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-header { padding-top: 12rem; padding-bottom: 6rem; }
	.content { padding: 8rem 0; }
	.news-card { padding: 2rem; border: 1px solid rgba(238, 234, 225, 0.1); }
	.date { font-size: 0.8rem; opacity: 0.5; display: block; margin-bottom: 1rem; }
</style>
