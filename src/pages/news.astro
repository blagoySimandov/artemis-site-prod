---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Coming Soon">
	<section class="page-header">
		<div class="container">
			<h1>Coming Soon</h1>
			<p>We are currently updating our digital platform with the latest strategic information.</p>
		</div>
	</section>
</Layout>

<style>
	.page-header {
		padding: 15rem 0;
		text-align: center;
	}
	h1 { font-size: 3.5rem; margin-bottom: 1.5rem; }
	p { opacity: 0.6; font-size: 1.25rem; }
</style>
