---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partnerships">
	<section class="page-header">
		<div class="container">
			<h1>Partnerships</h1>
			<p>Collaborating across the defense ecosystem.</p>
		</div>
	</section>

	<section class="content">
		<div class="container">
			<h2>Strategic Alliances</h2>
			<p>We work closely with government agencies, military branches, and prime contractors to facilitate technology transfer and market access for our portfolio.</p>
		</div>
	</section>
</Layout>

<style>
	.page-header { padding-top: 12rem; padding-bottom: 6rem; }
	.content { padding: 6rem 0; }
</style>
