---
import Layout from '../layouts/Layout.astro';

const pillars = [
	{
		num: "01",
		title: "GP-Led Platform",
		desc: "Experienced general partners drive investment strategy and execution, identifying and acquiring mid-market companies in the defence sector."
	},
	{
		num: "02",
		title: "Active Ownership",
		desc: "Hands-on operational support and value creation for portfolio companies, with C-level executives directly engaged in strategic direction."
	},
	{
		num: "03",
		title: "Institutional Governance",
		desc: "Rigorous frameworks and best practices ensure sustainable growth, transparent reporting, and institutional standards across the portfolio."
	}
];
---

<Layout title="Platform">
	<section class="page-header">
		<div class="container">
			<span class="eyebrow">Our Platform</span>
			<h1>Defence-Focused <span class="outline">Pledge Fund</span> Platform</h1>
			<p>Artemis Capital Partners identifies, acquires, and operates mid-market companies in the defence sector through disciplined capital, active ownership, and institutional governance.</p>
		</div>
	</section>

	<section class="platform-intro">
		<div class="container">
			<div class="grid grid-cols-2">
				<div>
					<span class="eyebrow">What We Do</span>
					<h2>A Disciplined Approach to Defence Investment</h2>
				</div>
				<div>
					<p class="lead">We combine sector expertise with institutional standards and a focus on long-term value creation. Our platform proactively identifies opportunities and actively engages with management teams to drive operational excellence and sustainable growth.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="pillars">
		<div class="container">
			<div class="section-header text-center">
				<span class="eyebrow">Platform Pillars</span>
				<h2>How Our <span class="outline">Platform Works</span></h2>
			</div>
			<div class="grid grid-cols-3 pillars-grid">
				{pillars.map(p => (
					<div class="pillar-card">
						<span class="num">{p.num}</span>
						<h3>{p.title}</h3>
						<p>{p.desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="process">
		<div class="container">
			<div class="grid grid-cols-2 process-grid">
				<div class="process-item">
					<span class="eyebrow">Deal Sourcing</span>
					<h3>Proactive Opportunity Identification</h3>
					<p>Our deep network across the European defence ecosystem allows us to identify opportunities early - before they reach the broader market. We leverage relationships with defence primes, government stakeholders, and industry associations across the EU and NATO regions.</p>
				</div>
				<div class="process-item">
					<span class="eyebrow">Operational Support</span>
					<h3>Hands-On Value Creation</h3>
					<p>Post-acquisition, our team of experienced C-level executives provides direct operational guidance. We support portfolio companies in governance optimization, commercial scaling, cross-border expansion, and preparation for institutional-grade exits.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="cta">
		<div class="container text-center">
			<h2>Learn More About Our Platform</h2>
			<p>Connect with our team to discuss how Artemis Capital Partners can deliver value in the defence sector.</p>
			<a href="/team" class="btn">Contact Our Team</a>
		</div>
	</section>
</Layout>

<style>
	.page-header {
		padding-top: 12rem;
		padding-bottom: 6rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
	}

	.page-header h1 {
		font-size: clamp(2.5rem, 5vw, 4rem);
		margin: 1.5rem 0 2rem;
		line-height: 1.1;
		max-width: 700px;
	}

	.page-header p {
		max-width: 600px;
		font-size: 1.1rem;
		opacity: 0.8;
		line-height: 1.6;
	}

	.outline {
		color: transparent;
		-webkit-text-stroke: 1px var(--color-primary);
	}

	.eyebrow {
		display: block;
		text-transform: uppercase;
		letter-spacing: 0.25em;
		font-size: 0.8rem;
		opacity: 0.6;
		margin-bottom: 1rem;
	}

	.platform-intro {
		padding: 8rem 0;
		background: var(--color-primary);
	}

	.platform-intro h2 {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		line-height: 1.2;
		padding-right: 3rem;
	}

	.lead {
		font-size: 1.15rem;
		opacity: 0.75;
		line-height: 1.7;
	}

	.pillars {
		padding: 8rem 0;
		background: #0f1521;
	}

	.section-header {
		margin-bottom: 5rem;
	}

	.text-center { text-align: center; }

	.pillars h2 {
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.pillars .outline {
		color: transparent;
		-webkit-text-stroke: 1px var(--color-secondary);
	}

	.pillars-grid {
		gap: 1px;
		background: rgba(238, 234, 225, 0.05);
		border: 1px solid rgba(238, 234, 225, 0.05);
	}

	.pillar-card {
		background: #0f1521;
		padding: 4rem 3rem;
		transition: background 0.4s ease;
	}

	.pillar-card:hover {
		background: #151d2b;
	}

	.pillar-card .num {
		display: block;
		font-family: monospace;
		font-size: 0.8rem;
		color: rgba(238, 234, 225, 0.2);
		margin-bottom: 2rem;
	}

	.pillar-card h3 {
		font-size: 1.4rem;
		color: var(--color-secondary);
		margin-bottom: 1.5rem;
	}

	.pillar-card p {
		font-size: 0.95rem;
		opacity: 0.6;
		line-height: 1.7;
	}

	.process {
		padding: 8rem 0;
		background: var(--color-primary);
		border-top: 1px solid rgba(238, 234, 225, 0.05);
	}

	.process-grid {
		gap: 4rem;
	}

	.process-item h3 {
		font-size: 1.75rem;
		margin: 1rem 0 2rem;
		line-height: 1.2;
	}

	.process-item p {
		font-size: 1rem;
		opacity: 0.7;
		line-height: 1.7;
	}

	.cta {
		padding: 8rem 0;
		background: #0d121c;
		border-top: 1px solid rgba(238, 234, 225, 0.05);
	}

	.cta h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.cta p {
		font-size: 1.1rem;
		opacity: 0.7;
		margin-bottom: 3rem;
	}

	.btn {
		display: inline-block;
		padding: 1.25rem 3rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		transition: opacity 0.3s ease, transform 0.3s ease;
	}

	.btn:hover {
		opacity: 0.9;
		transform: translateY(-2px);
	}

	@media (max-width: 1024px) {
		.pillars-grid {
			grid-template-columns: 1fr;
		}
		.process-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}

	@media (max-width: 768px) {
		.platform-intro {
			padding: 5rem 0;
		}
		.grid-cols-2 {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.platform-intro h2 {
			padding-right: 0;
		}
	}
</style>
