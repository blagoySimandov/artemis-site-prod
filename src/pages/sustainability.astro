---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sustainability">
	<section class="page-header">
		<div class="container">
			<h1>Sustainability</h1>
			<p>Responsible investment in the defense sector.</p>
		</div>
	</section>

	<section class="content">
		<div class="container">
			<div class="max-w-800">
				<h2>ESG in Defense</h2>
				<p>We believe that long-term security is inherently linked to sustainable practices. Our investment process integrates environmental, social, and governance considerations, ensuring that our portfolio companies operate with the highest ethical standards.</p>
			</div>
		</div>
	</section>
</Layout>

<style>
	.page-header { padding-top: 12rem; padding-bottom: 6rem; border-bottom: 1px solid rgba(238, 234, 225, 0.1); }
	.content { padding: 8rem 0; }
	.max-w-800 { max-width: 800px; }
	h2 { margin-bottom: 2rem; }
</style>
