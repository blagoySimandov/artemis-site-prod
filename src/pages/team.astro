---
import Layout from '../layouts/Layout.astro';

const team = [
	{
		name: "Andrey Bachvarov",
		role: "Investment Partner",
		bio: "Successful serial entrepreneur with deep connections in the international VC community. Currently board member at Endeavor Bulgaria and BESCO. Companies established by Andrey include Anthill (exited to Sun Capital's Exadel), EPIX.AI, Power Drone, BICA Services, and others.",
		image: "/Andrey-Bachvarov.jpg",
		email: "a.bachvarov@artemis-cp.eu"
	},
	{
		name: "Stefan Galabov",
		role: "Operational & Industry Partner",
		bio: "Significant sector experience, technical & commercial know-how and network in the defense industry globally. Currently General Manager of TBS Ltd., a leading international trading company providing advanced technological solutions in the defense industry. Member of BDIA and AFCEA International.",
		image: "/Stefan-Galabov.jpg",
		email: "s.galabov@artemis-cp.eu"
	},
	{
		name: "Stanislav Georgiev",
		role: "Operational Partner",
		bio: "Seasoned CEO with 20+ years in telecom, satellite and media, recognized for executing complex transformations, spin-offs and institutional-grade exits for PE investors. Previous roles include CEO of Bulsatcom, Director of A1 Broadcasting, CIO of A1 Telekom Serbia, as well as senior advisory roles with Arthur D. Little and Intelsat.",
		image: "/Stanislav-Georgiev.jpg",
		email: "s.georgiev@artemis-cp.eu"
	}
];
---

<Layout title="Team">
	<section class="page-header">
		<div class="container">
			<span class="eyebrow">Leadership</span>
			<h1>Our <span class="outline">Team</span></h1>
			<p>Operator-led leadership with deep technical and commercial expertise.</p>
		</div>
	</section>

	<section class="philosophy">
		<div class="container">
			<div class="grid grid-cols-2">
				<div>
					<h2>Expertise and Integrity at the Core</h2>
				</div>
				<div>
					<p>We believe that the strength of Artemis Capital Partners lies in our people. Our team's diverse backgrounds in finance, defence, and operational leadership enable us to deliver value to investors and portfolio companies alike.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="team-grid-section">
		<div class="container">
			<div class="grid grid-cols-3 team-grid">
				{team.map(member => (
					<div class="member-card">
						<div class="member-image">
							<img src={member.image} alt={member.name} />
							<div class="image-overlay"></div>
						</div>
						<div class="member-info">
							<span class="role">{member.role}</span>
							<h3>{member.name}</h3>
							<div class="divider"></div>
							<p>{member.bio}</p>
							<a href={`mailto:${member.email}`} class="member-email">{member.email}</a>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="team-cta">
		<div class="container text-center">
			<h2>Work With Our Team</h2>
			<p>Connect with us to learn more about our platform and investment opportunities.</p>
			<a href="mailto:contact@artemis-cp.eu" class="btn">Contact Our Team</a>
		</div>
	</section>
</Layout>

<style>
	.page-header { 
		padding-top: 12rem; 
		padding-bottom: 4rem; 
		border-bottom: 1px solid rgba(238, 234, 225, 0.05);
	}
	.eyebrow { 
		display: block; 
		text-transform: uppercase; 
		letter-spacing: 0.3em; 
		font-size: 0.8rem; 
		margin-bottom: 1rem; 
		opacity: 0.5;
	}
	.outline { color: transparent; -webkit-text-stroke: 1px var(--color-secondary); }

	.philosophy {
		padding: 6rem 0;
		background: #0d121c;
		border-bottom: 1px solid rgba(238, 234, 225, 0.05);
	}

	.philosophy h2 {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
		line-height: 1.2;
	}

	.philosophy p {
		font-size: 1.1rem;
		opacity: 0.75;
		line-height: 1.7;
	}

	.member-email {
		display: inline-block;
		margin-top: 1.5rem;
		font-size: 0.75rem;
		opacity: 0.4;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: opacity 0.3s ease;
		font-family: monospace;
	}

	.member-email:hover {
		opacity: 0.8;
	}

	.team-cta {
		padding: 6rem 0 8rem;
		background: var(--color-primary);
		border-top: 1px solid rgba(238, 234, 225, 0.05);
	}

	.team-cta h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.team-cta p {
		font-size: 1.1rem;
		opacity: 0.7;
		margin-bottom: 3rem;
	}

	.btn {
		display: inline-block;
		padding: 1.25rem 3rem;
		background-color: var(--color-secondary);
		color: var(--color-primary);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		transition: opacity 0.3s ease, transform 0.3s ease;
		text-decoration: none;
	}

	.btn:hover {
		opacity: 0.9;
		transform: translateY(-2px);
	}

	.team-grid-section { padding: 4rem 0 8rem; }
	
	.team-grid { gap: 3rem; }

	.member-card { 
		background: rgba(24, 33, 50, 0.3); 
		border: 1px solid rgba(238, 234, 225, 0.05);
		transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.member-card:hover {
		transform: translateY(-10px);
		border-color: rgba(238, 234, 225, 0.2);
	}

	.member-image { 
		aspect-ratio: 4/5; 
		overflow: hidden;
		position: relative;
		background: #0d121c;
	}

	.member-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: grayscale(1) contrast(1.1);
		transition: filter 0.5s ease, transform 0.5s ease;
	}

	.member-card:hover .member-image img {
		filter: grayscale(0.5) contrast(1);
		transform: scale(1.05);
	}

	.image-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to bottom, transparent 60%, rgba(24, 33, 50, 0.8));
	}

	.member-info { padding: 2.5rem; }
	
	.role { 
		display: block; 
		font-size: 0.7rem; 
		opacity: 0.4; 
		text-transform: uppercase; 
		letter-spacing: 0.15em;
		margin-bottom: 0.75rem; 
		font-weight: 600;
	}

	h3 { 
		margin-bottom: 1.5rem; 
		font-size: 1.4rem;
		letter-spacing: 0.02em;
	}

	.divider {
		width: 30px;
		height: 2px;
		background: var(--color-secondary);
		margin-bottom: 1.5rem;
		opacity: 0.3;
	}

	p { 
		font-size: 0.9rem; 
		opacity: 0.6; 
		line-height: 1.7; 
		font-weight: 300;
	}

	@media (max-width: 1024px) {
		.grid-cols-3 { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 640px) {
		.grid-cols-3 { grid-template-columns: 1fr; }
		.team-grid-section { padding: 4rem 0; }
	}
</style>
